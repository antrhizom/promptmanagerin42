rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin-Allow-Liste — MUSS mit lib/constants.ts (ADMIN_EMAILS) übereinstimmen.
    // Env-Variablen sind in Rules nicht verfügbar, daher hier fest hinterlegt.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['antrhizom@gmail.com'];
    }

    // Nur die Kopier-Zählung darf anonym erhöht werden (exakt +1, kein anderes Feld).
    function isUsageIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nutzungsanzahl'])
        && request.resource.data.nutzungsanzahl is int
        && request.resource.data.nutzungsanzahl == resource.data.nutzungsanzahl + 1;
    }

    // ============================================
    // PROMPTS — öffentlich lesbar.
    // Kern-Inhalte (Titel, Text, ...) NUR Admin.
    // Besucher dürfen nur: Kopier-Zähler +1, Liken (bewertungen) und Kommentieren (kommentare).
    // Die Werte werden serverseitig (API-Routes) kontrolliert gesetzt; diese Regeln
    // stellen sicher, dass kein anderes Feld verändert werden kann.
    // ============================================
    match /prompts/{promptId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin()
        || isUsageIncrement()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bewertungen'])
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kommentare']);
      allow delete: if isAdmin();
    }

    // ============================================
    // KI-TOOLS — Verzeichnis von KI-Assistenten/Generatoren.
    // Öffentlich lesbar; Inhalte nur Admin. Besucher dürfen nur 'bewertungen' (Liken) ändern.
    // ============================================
    match /kiTools/{toolId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bewertungen']);
      allow delete: if isAdmin();
    }

    // ============================================
    // SUBMISSIONS — Community-Einreichungen (neue Prompts / KI-Tools).
    // Jeder darf eine Einreichung mit status 'pending' anlegen; Lesen/Verwalten nur Admin.
    // So sind unfreigeschaltete Inhalte NIE öffentlich sichtbar.
    // ============================================
    match /submissions/{subId} {
      allow create: if
        request.resource.data.keys().hasOnly(['type', 'data', 'autorEmail', 'emailOeffentlich', 'status', 'createdAt']) &&
        request.resource.data.type in ['prompt', 'kitool'] &&
        request.resource.data.status == 'pending' &&
        request.resource.data.data is map &&
        request.resource.data.autorEmail is string &&
        request.resource.data.autorEmail.size() <= 200 &&
        request.resource.data.emailOeffentlich is bool &&
        request.resource.data.createdAt is timestamp;
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // ANALYTICS — anonyme Besucher dürfen NUR Events anlegen (append-only),
    // Lesen nur Admin, kein Update/Delete.
    // ============================================
    match /analytics/{eventId} {
      allow create: if
        request.resource.data.keys().hasOnly(['type', 'name', 'plattform', 'ts', 'session']) &&
        request.resource.data.type is string &&
        request.resource.data.type in ['visit', 'function', 'action'] &&
        request.resource.data.ts is timestamp &&
        (!('name' in request.resource.data) ||
          (request.resource.data.name is string && request.resource.data.name.size() <= 120)) &&
        (!('plattform' in request.resource.data) ||
          (request.resource.data.plattform is string && request.resource.data.plattform.size() <= 120)) &&
        (!('session' in request.resource.data) ||
          (request.resource.data.session is string && request.resource.data.session.size() <= 80));
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ============================================
    // USERS — Namens-Login fürs Kommentieren. Jeder darf einen User anlegen
    // (Name + Code), Lesen nur Admin. Kein Update/Delete durch Besucher.
    // ============================================
    match /users/{userId} {
      allow read: if isAdmin();
      allow create: if
        request.resource.data.keys().hasOnly(['username', 'createdAt']) &&
        request.resource.data.username is string &&
        request.resource.data.username.size() > 0 &&
        request.resource.data.username.size() <= 100 &&
        request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    // ============================================
    // ALLE ANDEREN COLLECTIONS: Verbieten
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
