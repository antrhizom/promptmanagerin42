# Firebase Configuration
# Ersetze alle Werte mit deinen eigenen Firebase-Werten

NEXT_PUBLIC_FIREBASE_API_KEY=dein-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=dein-projekt.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=dein-projekt-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=dein-projekt.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# E-Mail-Benachrichtigung via Resend (optional – ohne diese Werte wird einfach
# keine Mail verschickt; Einreichungen/Wünsche sind trotzdem im Dashboard sichtbar)
RESEND_API_KEY=re_dein_api_key
ADMIN_NOTIFY_EMAIL=deine-admin-adresse@beispiel.ch
# Absender; bis eine eigene Domain bei Resend verifiziert ist, kann der Testabsender bleiben:
MAIL_FROM=Promptmanagerin <onboarding@resend.dev>
